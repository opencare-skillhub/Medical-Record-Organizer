# Patient Record Organizer - 环境变量配置示例
# 复制此文件为 .env 并填入真实 Key

# 可选：SiliconFlow DeepSeek-OCR（作为 MinerU 失败后的 fallback）
# 兼容旧变量名 SILICONFLOW_API_KEY / SILICONFLOW_BASE_URL
OCR_API_KEY=sk-xxxxxxxx
OCR_BASE_URL=https://api.siliconflow.cn/v1
OCR_MODEL=deepseek-ai/DeepSeek-OCR

# 必需：MinerU（复杂/扫描 PDF 深度解析）
# Key 名称兼容两种写法：MINERU_API_KEY 或 MINERU_TOKEN
MINERU_API_KEY=your-mineru-token
# MINERU_API_URL=https://mineru.net  # 官方默认地址，自建实例可覆盖
# MINERU_MODEL_VERSION=vlm  # 模型版本：pipeline / vlm（默认 vlm）

# 必需：StepFun（录音 ASR：StepAudio 2.5 SSE 主力 + step-asr-1.1 异步备选）
STEP_API_KEY=sk-xxxxxxxx
STEP_API_BASE_URL=https://api.stepfun.com/v1

# v2 LLM 模型配置（格式 provider:model）
# provider 取值：stepfun / siliconflow / openai
# 失败时按 LLM_FALLBACK_MODELS 顺序降级
LLM_DEFAULT_MODEL=stepfun:step-3.5-flash
LLM_FALLBACK_MODELS=stepfun:step-3.5-flash,siliconflow:deepseek-ai/DeepSeek-V4-Flash

# 推荐：DashScope（语义分类 LLM，可选作 Enricher）
DASHSCOPE_API_KEY=sk-xxxxxxxx

# 可选：通用 OpenAI 兼容接口（可作为 LLM fallback）
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：EdgeOne Pages 公网发布（xyb process --publish 时需要）
EDGEONE_PAGES_API_TOKEN=your-edgeone-token

# 可选：其他 LLM 厂商 fallback（参考 fastgpt-content-processor 模式）
# ZHIPUAI_API_KEY=your-zhipuai-key
