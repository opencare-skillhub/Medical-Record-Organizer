"""
全流程处理管道（Pipeline）

把收集 → OCR/提取 → 分类 → 危急值 → 时间线 → 基因 → manifest → 报告
串联成一条命令，支持增量更新和 JSON 缓存复用。
"""
from __future__ import annotations

import json
import logging
import os
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

# 自动加载 .env（如果存在）
_ProjectRoot = Path(__file__).resolve().parent.parent
_dotenv_path = _ProjectRoot / ".env"
if _dotenv_path.exists():
    try:
        from dotenv import load_dotenv
        load_dotenv(str(_dotenv_path), override=True)
    except ImportError:
        pass  # python-dotenv 未安装时静默跳过

from scripts import classify, critical_values, ingest, manifest, parse_genetics, render_report
from scripts.route_ocr import extract_text as route_extract_text, route_ocr
from scripts.publisher_edgeone import publish as _publish_site, publish_report as _publish_report
from scripts.memory import record_run, recall_version, list_versions, diff_versions, rollback
from scripts.security import ensure_private_dir, write_private_text

logger = logging.getLogger(__name__)

# 分类中文名映射（用于输出展示）
_CATEGORY_NAMES = {
    "basic_info": "👤 基本信息",
    "lab_results": "📊 检验指标",
    "imaging": "🏥 影像检查",
    "pathology": "🔬 病理报告",
    "genetics": "🧬 基因检测",
    "medication": "💊 用药方案",
    "clinical_records": "📝 诊疗记录",
    "key_concerns": "⚠️ 关注问题要点",
    "consultation": "💬 问诊咨询建议",
    "other": "⚠️ 待确认",
}


# ---------------------------------------------------------------------------
# 结果数据结构
# ---------------------------------------------------------------------------

@dataclass
class PipelineResult:
    patient_id: str
    files_total: int = 0
    files_processed: int = 0      # 成功提取文本
    files_pending_ocr: int = 0
    files_failed: int = 0
    timeline_events: int = 0
    critical_alerts: int = 0
    genetic_highlights: int = 0
    output_dir: Optional[Path] = None
    manifest_path: Optional[Path] = None
    category_summary: Dict[str, int] = field(default_factory=dict)
    report_paths: List[Path] = field(default_factory=list)
    publish_url: Optional[str] = None
    publish_status: Optional[str] = None


# ---------------------------------------------------------------------------
# JSON 缓存复用
# ---------------------------------------------------------------------------

def _discover_json_caches(root: Path) -> Dict[str, Path]:
    """扫描目录下所有 JSON 缓存，建立 原始文件路径/文件名 -> JSON路径 的映射。"""
    mapping: Dict[str, Path] = {}
    for json_path in root.rglob("*.json"):
        try:
            data = json.loads(json_path.read_text(encoding="utf-8"))
            for key in ("original_file", "new_filename"):
                val = data.get(key, "")
                if val:
                    mapping[val] = json_path
                    mapping[Path(val).name] = json_path
        except Exception:
            continue
    return mapping


_CAT_MAP = {
    "处方用药": "medication",
    "检验指标": "lab_results",
    "影像检查": "imaging",
    "病理报告": "pathology",
    "诊疗记录": "medical_records",
    "基本信息": "basic_info",
}


def _load_json_cache(json_path: Path) -> Tuple[str, str]:
    """加载已有的 OCR JSON 缓存，返回 (分类, 文本内容)。"""
    try:
        data = json.loads(json_path.read_text(encoding="utf-8"))
        raw = data.get("raw_data", {})
        text = raw.get("full_text", "") or data.get("content_summary", "")
        cat = _CAT_MAP.get(data.get("category_cn", ""), "other")
        return cat, text
    except Exception as exc:
        logger.debug("JSON 缓存读取失败 %s: %s", json_path, exc)
        return "other", ""


# ---------------------------------------------------------------------------
# 内容提取器
# ---------------------------------------------------------------------------

def _extract_pdf_text(pdf_path: Path) -> str:
    """用 PyMuPDF 提取 PDF 文本。"""
    try:
        import fitz
        doc = fitz.open(pdf_path)
        parts = [page.get_text() for page in doc]
        doc.close()
        return "\n".join(parts)
    except Exception as exc:
        logger.warning("PDF 提取失败 %s: %s", pdf_path, exc)
        return "[PDF提取失败-需人工确认]"


def _extract_docx_text(docx_path: Path) -> str:
    """提取 DOCX 段落与表格文本。"""
    try:
        from docx import Document
        doc = Document(str(docx_path))
    except Exception as exc:
        logger.warning("DOCX 提取失败 %s: %s", docx_path, exc)
        return "[DOCX提取失败-需人工确认]"

    parts: List[str] = []
    for para in getattr(doc, "paragraphs", []) or []:
        text = getattr(para, "text", "").strip()
        if text:
            parts.append(text)

    for table in getattr(doc, "tables", []) or []:
        for row in getattr(table, "rows", []) or []:
            cells = []
            for cell in getattr(row, "cells", []) or []:
                text = getattr(cell, "text", "").strip()
                if text:
                    cells.append(text)
            if cells:
                parts.append("\t".join(cells))

    return "\n".join(parts)


def _convert_heic_to_jpg(src: Path, dest_dir: Path) -> Path:
    """将 HEIC/HEIF 图片转为 JPG，返回转换后的路径。"""
    dest = dest_dir / f"{src.stem}.jpg"
    if dest.exists():
        return dest
    dest_dir.mkdir(parents=True, exist_ok=True)
    try:
        from PIL import Image
        img = Image.open(src)
        img.save(dest, "JPEG", quality=90)
        logger.info("HEIC 转换成功(PIL): %s -> %s", src.name, dest.name)
        return dest
    except Exception as exc:
        logger.debug("PIL 转换 HEIC 失败 %s: %s，尝试 sips", src, exc)
    try:
        subprocess.run(
            ["sips", "-s", "format", "jpeg", str(src), "--out", str(dest)],
            check=True,
            capture_output=True,
        )
        logger.info("HEIC 转换成功(sips): %s -> %s", src.name, dest.name)
        return dest
    except Exception as exc:
        logger.warning("HEIC 转换失败 %s: %s", src, exc)
        return src


def _build_ocr_config() -> Tuple[Optional[str], str, str]:
    """从环境变量读取 OCR 配置，返回 (api_key, base_url, model)。"""
    key = os.getenv("OCR_API_KEY") or os.getenv("SILICONFLOW_API_KEY", "")
    base = os.getenv("OCR_BASE_URL") or os.getenv("SILICONFLOW_BASE_URL", "https://api.siliconflow.cn/v1")
    model = os.getenv("OCR_MODEL", "deepseek-ai/DeepSeek-OCR")
    return key, base.rstrip("/"), model


# ---------------------------------------------------------------------------
# 患者信息自动提取
# ---------------------------------------------------------------------------

def _extract_patient_info(texts: List[str]) -> Dict[str, Any]:
    """从提取的文本中自动推断患者基本信息。"""
    info = {"name": "", "age": None, "gender": ""}
    if not texts:
        return info

    combined = "\n".join(texts[:3])  # 只检查前几份文件

    # 姓名：匹配"姓名：XXX"或"患者：XXX"模式
    import re
    for pat in [r"患者姓名[：\s]*([\u4e00-\u9fa5]{2,4})", r"姓名[：\s]*([\u4e00-\u9fa5]{2,4})"]:
        m = re.search(pat, combined)
        if m:
            info["name"] = m.group(1)
            break

    # 年龄：匹配"年龄：XX岁"或"XX岁"
    m = re.search(r"年龄[：\s]*(\d+)\s*岁", combined)
    if m:
        info["age"] = int(m.group(1))
    else:
        m = re.search(r"(\d{1,2})\s*岁", combined)
        if m:
            info["age"] = int(m.group(1))

    # 性别：匹配"性别：男/女"
    m = re.search(r"性别[：\s]*(男|女)", combined)
    if m:
        info["gender"] = m.group(1)

    return info


def _auto_patient_id(input_dir: str | Path) -> str:
    """从输入目录名或时间戳自动生成患者ID。"""
    p = Path(input_dir)
    name = p.name
    if name and not name.startswith("."):
        # 清理非法字符，保留中文、字母、数字、下划线
        import re
        clean = re.sub(r"[^\u4e00-\u9fa5a-zA-Z0-9_]", "_", name)
        return f"P_{clean[:20]}"
    from datetime import datetime
    return f"P_{datetime.now().strftime('%Y%m%d_%H%M%S')}"


# ---------------------------------------------------------------------------
# 主流程（极简接口）
# ---------------------------------------------------------------------------

def run(
    input_dir: str | Path,
    *,
    patient_id: Optional[str] = None,
    patient_dir: Optional[str | Path] = None,
    output_format: str = "both",  # md / html / pdf / docx / both / all
    extract_dir: Optional[str | Path] = None,
    publish: bool = False,       # 是否发布到 EdgeOne Pages
    confirm_public: bool = False,
    desensitize_public: bool = True,
    publish_dry_run: bool = False,
    verbose: bool = True,
) -> PipelineResult:
    """执行完整的病案整理流程。

    只需要输入目录，患者信息自动从文件中提取。

    Parameters
    ----------
    input_dir : 输入目录
    patient_id : 患者ID（默认从目录名自动生成）
    patient_dir : 患者工作目录（默认 ~/patients/{patient_id}）
    output_format : 报告输出格式
    extract_dir : 解压/提取临时目录
    verbose : 是否打印进度信息

    Returns
    -------
    PipelineResult
    """
    # 自动生成患者ID
    if not patient_id:
        patient_id = _auto_patient_id(input_dir)

    result = PipelineResult(patient_id=patient_id)

    p_dir = ensure_private_dir(Path(patient_dir) if patient_dir else Path.home() / "patients" / patient_id)
    out_dir = ensure_private_dir(p_dir / "output")
    result.output_dir = out_dir

    ext_dir = ensure_private_dir(Path(extract_dir) if extract_dir else p_dir / "extracted")

    def _log(msg: str):
        if verbose:
            print(msg)
        logger.info(msg)

    _log("=" * 60)
    _log("📂 智能病案整理助手")
    _log(f"   输入目录: {input_dir}")
    _log(f"   患者ID: {patient_id}")
    _log("=" * 60)

    # ── 步骤1：收集文件 ──
    _log("\n【步骤1】收集文件...")
    files = ingest.collect([str(input_dir)], extract_dir=str(ext_dir))
    result.files_total = len(files)
    img_count = sum(1 for _, t in files if t == "image")
    pdf_count = sum(1 for _, t in files if t == "pdf")
    txt_count = sum(1 for _, t in files if t == "text")
    _log(f"   收集到 {len(files)} 个可处理文件")
    _log(f"   ├── 图片: {img_count} 张")
    _log(f"   ├── PDF: {pdf_count} 份")
    _log(f"   └── 文本: {txt_count} 份")

    # ── 步骤2：初始化/加载 manifest ──
    _log("\n【步骤2】初始化患者档案...")
    m, is_new = manifest.init_or_load(
        patient_id,
        patient_dir=p_dir,
        name="",   # 将从文件中自动提取
        age=None,
        gender="",
    )
    _log(f"   {'新建' if is_new else '加载已有'}档案: {patient_id}")

    # ── 增量缓存检查：如果文件未变且已有 report_context，直接复用 ──
    _reuse_ctx: Optional[Dict[str, Any]] = None
    current_hashes = set()
    for fp, _ in files:
        try:
            current_hashes.add(manifest.sha256_of(Path(fp)))
        except Exception:
            pass
    existing_hashes = {entry["hash"] for entry in m.get("files", []) if entry.get("hash")}
    new_input_files = manifest.diff_files(m, files) if not is_new else list(files)
    if not is_new and current_hashes == existing_hashes and m.get("report_context"):
        _reuse_ctx = m["report_context"]
        _log("   ♻️ 增量更新：文件未变化，复用已有计算结果")
    elif new_input_files:
        m["report_context"] = None

    # ── 步骤3：内容提取（跳过已缓存）──
    _log("\n【步骤3】内容提取（OCR/ASR/解析）...")
    extracted_texts: List[str] = []
    file_records: List[Dict[str, Any]] = []
    json_cache_map = _discover_json_caches(Path(input_dir))
    sf_key, sf_url, sf_model = _build_ocr_config()
    mineru_key = os.getenv("MINERU_API_KEY") or os.getenv("MINERU_TOKEN", "")
    mineru_url = os.getenv("MINERU_API_URL", "")
    mineru_model = os.getenv("MINERU_MODEL_VERSION", "vlm")
    step_key = os.getenv("STEP_API_KEY")

    # ── 去重：按内容 hash 去重，避免重复处理同名/同内容文件 ──
    seen_content_hashes: set = set()
    dedup_skipped = 0

    def _dedup_check(p: Path) -> bool:
        """返回 True 表示应跳过（重复文件）"""
        nonlocal dedup_skipped
        try:
            h = manifest.sha256_of(p)
        except Exception:
            return False
        if h in seen_content_hashes:
            dedup_skipped += 1
            return True
        seen_content_hashes.add(h)
        return False

    for file_path, file_type in new_input_files:
        p = Path(file_path)

        # 0. 去重检查：同内容文件只处理一次
        if _dedup_check(p):
            _log(f"   {p.name} → 跳过（重复文件）")
            continue

        # 3a. JSON 缓存复用
        json_cache = json_cache_map.get(str(p)) or json_cache_map.get(p.name)
        if json_cache and json_cache.exists():
            cat, text = _load_json_cache(json_cache)
            if text:
                _log(f"   {p.name} → JSON 缓存 ({len(text)} 字符) [{cat}]")
                extracted_texts.append(text)
                file_records.append({
                    "path": str(p), "type": file_type, "text": text,
                    "category": cat, "source": "json_cache",
                })
                result.files_processed += 1
                continue

        # 3b. PDF/图片统一解析路由：文字型 PDF 可本地提取，不强制要求 OCR Key
        if file_type in {"pdf", "image"}:
            original_path = p
            if p.suffix.lower() in {".heic", ".heif"}:
                p = _convert_heic_to_jpg(p, ext_dir)
            engine = route_ocr(p)
            if engine == "local_pdf" or sf_key or mineru_key:
                text = route_extract_text(
                    p,
                    sf_api_key=sf_key,
                    sf_api_url=sf_url,
                    sf_model=sf_model,
                    mineru_api_key=mineru_key,
                    mineru_api_url=mineru_url,
                    model_version=mineru_model,
                    extract_dir=ext_dir,
                )
                if text.startswith("["):
                    _log(f"   {original_path.name} → OCR/解析失败: {text}")
                    file_records.append({
                        "path": str(original_path), "type": file_type, "text": text,
                        "category": None, "source": "ocr_failed",
                    })
                    result.files_failed += 1
                else:
                    _log(f"   {original_path.name} → {engine} 成功 ({len(text)} 字符)")
                    extracted_texts.append(text)
                    file_records.append({
                        "path": str(original_path), "type": file_type, "text": text,
                        "category": None, "source": engine,
                    })
                    result.files_processed += 1
            else:
                _log(f"   {original_path.name} → OCR 暂跳（无 MINERU_API_KEY/MINERU_TOKEN 或 OCR_API_KEY）")
                file_records.append({
                    "path": str(original_path), "type": file_type,
                    "text": "[OCR待处理-需配置 OCR API Key]",
                    "category": None, "source": "pending_ocr",
                })
                result.files_pending_ocr += 1
            continue

        # 3d. 音频 ASR 转写（StepAudio 2.5 SSE）
        if file_type == "audio":
            if step_key:
                try:
                    from scripts.asr_stepfun import transcribe as _asr_transcribe
                    text = _asr_transcribe(p, api_key=step_key)
                    if text.startswith("["):
                        raise RuntimeError(text)
                    _log(f"   {p.name} → ASR 转写成功 ({len(text)} 字符)")
                    extracted_texts.append(text)
                    file_records.append({
                        "path": str(p), "type": file_type, "text": text,
                        "category": None, "source": "asr_stepfun",
                    })
                    result.files_processed += 1
                except Exception as exc:
                    _log(f"   {p.name} → ASR 转写失败: {exc}")
                    file_records.append({
                        "path": str(p), "type": file_type,
                        "text": "[ASR失败-需人工确认]",
                        "category": None, "source": "asr_failed",
                    })
                    result.files_failed += 1
            else:
                _log(f"   {p.name} → 音频暂跳（无 STEP_API_KEY）")
                file_records.append({
                    "path": str(p), "type": file_type,
                    "text": "[ASR待处理-需配置 STEP_API_KEY]",
                    "category": None, "source": "pending_asr",
                })
                result.files_pending_ocr += 1
            continue

        # 3e. DOCX 文档解析
        if file_type == "docx":
            text = _extract_docx_text(p)
            if text and not text.startswith("["):
                _log(f"   {p.name} → DOCX 提取 ({len(text)} 字符)")
                extracted_texts.append(text)
                file_records.append({
                    "path": str(p), "type": file_type, "text": text,
                    "category": None, "source": "docx_extract",
                })
                result.files_processed += 1
            else:
                _log(f"   {p.name} → DOCX 提取失败")
                file_records.append({
                    "path": str(p), "type": file_type,
                    "text": text or "[DOCX提取失败-需人工确认]",
                    "category": None, "source": "docx_failed",
                })
                result.files_failed += 1
            continue

        # 3f. 其他文本文件直接读取
        try:
            text = p.read_text(encoding="utf-8")
            extracted_texts.append(text)
            file_records.append({
                "path": str(p), "type": file_type, "text": text,
                "category": None, "source": "direct_read",
            })
            result.files_processed += 1
        except Exception as exc:
            logger.warning("文件读取失败 %s: %s", p, exc)
            file_records.append({
                "path": str(p), "type": file_type,
                "text": "[读取失败]", "category": None, "source": "error",
            })
            result.files_failed += 1

    if dedup_skipped > 0:
        _log(f"   🗂️ 去重：跳过 {dedup_skipped} 个重复文件")

    # ── 步骤4：自动分类 ──
    _log("\n【步骤4】自动分类...")
    category_counts: Dict[str, int] = {}
    timeline_entries: List[Dict] = []

    for rec in file_records:
        if rec.get("source") == "json_cache" and rec.get("category"):
            primary = rec["category"]
        elif rec.get("text") and not rec["text"].startswith("["):
            primary, _, _ = classify.classify(rec["text"])
            rec["category"] = primary
        else:
            primary = "other"
            rec["category"] = primary

        category_counts[primary] = category_counts.get(primary, 0) + 1

        if rec.get("text") and not rec["text"].startswith("["):
            dates = classify._extract_dates(rec["text"])
            rec["dates"] = dates
            if dates:
                entry = classify.build_timeline_entry(
                    rec["path"], primary, dates, title=Path(rec["path"]).name
                )
                timeline_entries.append(entry)
        else:
            rec["dates"] = []

    result.category_summary = category_counts
    result.timeline_events = len(timeline_entries)

    _log("\n   📋 分类结果：")
    for cat, count in sorted(category_counts.items(), key=lambda x: -x[1]):
        _log(f"   ├── {_CATEGORY_NAMES.get(cat, cat)}: {count} 份")

    # ── 步骤5：危急值检测 ──
    _log("\n【步骤5】危急值检测...")
    all_text = "\n".join(t for t in extracted_texts if t and not t.startswith("["))
    alerts = critical_values.check_critical_values(all_text) if all_text else []
    result.critical_alerts = len(alerts)
    if alerts:
        _log(f"   ⚠️ 发现 {len(alerts)} 项危急值/异常指标：")
        for a in alerts[:10]:
            emoji = "🔴" if a.level >= 4 else "🟠" if a.level >= 3 else "🟡"
            _log(f"   {emoji} {a.message}")
    else:
        _log("   ✅ 未发现危急值")

    # ── 步骤6：基因/病理信息提取 ──
    _log("\n【步骤6】基因/病理信息提取...")
    genetic = parse_genetics.parse_genetics(all_text) if all_text else []
    result.genetic_highlights = len(genetic)
    if genetic:
        _log(f"   提取到 {len(genetic)} 条基因/病理信息")
        for g in genetic[:5]:
            desc = g.mutation or g.immune_marker or g.pathology_type or "详见报告"
            _log(f"   • {g.gene}: {desc}")
    else:
        _log("   未提取到基因/病理信息")

    # ── 步骤7：时间线排序 ──
    timeline_entries.sort(key=lambda x: x.get("dates", [""])[0] or "")

    # ── 步骤8：更新 manifest ──
    _log("\n【步骤7】更新 manifest...")
    processed_files = [(r["path"], r["type"]) for r in file_records]
    m = manifest.append_files(m, processed_files)

    entries_by_hash = {
        entry.get("hash"): entry
        for entry in m.get("files", [])
        if entry.get("hash")
    }
    ensure_private_dir(ext_dir)

    for rec in file_records:
        src = Path(rec["path"])
        try:
            h = manifest.sha256_of(src)
        except Exception:
            continue
        entry = entries_by_hash.get(h)
        if not entry:
            continue
        text = rec.get("text") or ""
        extracted_path = ext_dir / f"{h}.txt"
        if text:
            write_private_text(extracted_path, text, encoding="utf-8")
        entry["category"] = rec["category"]
        entry["date_detected"] = rec["dates"][0] if rec.get("dates") else None
        entry["title"] = src.name
        entry["extracted_path"] = str(extracted_path) if text else None
        entry["source"] = rec.get("source")

    # 自动提取并回写患者信息
    info = _extract_patient_info(extracted_texts)
    if info["name"] and not m["demographics"].get("name"):
        m["demographics"]["name"] = info["name"]
        _log(f"   📝 自动提取患者姓名: {info['name']}")
    if info["age"] and not m["demographics"].get("age"):
        m["demographics"]["age"] = info["age"]
        _log(f"   📝 自动提取患者年龄: {info['age']}岁")
    if info["gender"] and not m["demographics"].get("gender"):
        m["demographics"]["gender"] = info["gender"]
        _log(f"   📝 自动提取患者性别: {info['gender']}")

    classify.update_categories_summary(m)
    result.manifest_path = manifest.write_manifest(m, patient_dir=p_dir)
    _log("   manifest 已更新")

    # ── 步骤9：生成报告（一次计算，多格式复用）──
    _log("\n【步骤8】生成病例档案...")

    if _reuse_ctx is not None:
        # 增量模式：直接复用缓存的 report_context
        report_ctx = _reuse_ctx
        alerts = report_ctx.get("critical_alerts", [])
        _log("   ♻️ 复用缓存的分析结果")
    else:
        # 全量或部分更新：重新计算
        extra = {"extracted_texts": extracted_texts}
        report_ctx = render_report.compute_report_context(
            m, timeline=timeline_entries, extracted_texts=extracted_texts
        )
        alerts = report_ctx.get("critical_alerts", [])
        # 将计算结果写回 manifest，供下次增量复用
        m["report_context"] = report_ctx
        result.manifest_path = manifest.write_manifest(m, patient_dir=p_dir)
        _log("   💾 分析结果已缓存到 manifest")

    fmt = output_format
    gen_md = fmt in ("md", "both", "all")
    gen_html = fmt in ("html", "both", "all")
    gen_pdf = fmt in ("pdf", "all")
    gen_docx = fmt in ("docx", "all")

    if gen_md:
        path = render_report.render_md(m, timeline=timeline_entries, output_path=out_dir / "case_report.md", report_context=report_ctx)
        _log(f"   ✅ Markdown: {path}")
        result.report_paths.append(Path(path))
    if gen_html:
        try:
            path = render_report.render_html(m, timeline=timeline_entries, output_path=out_dir / "case_report.html", report_context=report_ctx)
            _log(f"   ✅ HTML: {path}")
            result.report_paths.append(Path(path))
        except RuntimeError as exc:
            _log(f"   ⚠️ HTML 生成跳过: {exc}")
    if gen_pdf:
        try:
            path = render_report.render_pdf(m, timeline=timeline_entries, output_path=out_dir / "case_report.pdf", report_context=report_ctx)
            _log(f"   ✅ PDF: {path}")
            result.report_paths.append(Path(path))
        except RuntimeError as exc:
            _log(f"   ⚠️ PDF 生成跳过: {exc}")
    if gen_docx:
        try:
            path = render_report.render_docx(m, timeline=timeline_entries, output_path=out_dir / "case_report.docx", report_context=report_ctx)
            _log(f"   ✅ Word: {path}")
            result.report_paths.append(Path(path))
        except RuntimeError as exc:
            _log(f"   ⚠️ Word 生成跳过: {exc}")

    # ── 摘要 ──
    _log("\n" + "=" * 60)
    _log("📋 处理完成摘要")
    _log("=" * 60)
    _log(f"   患者: {m['demographics']['name'] or patient_id}")
    if m['demographics'].get('age'):
        _log(f"   年龄: {m['demographics']['age']}岁")
    _log(f"   处理文件: {result.files_total} 个")
    _log(f"   成功提取: {result.files_processed} 个")
    _log(f"   待 OCR: {result.files_pending_ocr} 个")
    _log(f"   失败: {result.files_failed} 个")
    _log(f"   时间线事件: {result.timeline_events} 个")
    _log(f"   危急值: {result.critical_alerts} 项")
    _log(f"   输出目录: {out_dir}")
    _log("=" * 60)
    _log("\n⚠️ 免责声明：本报告仅用于资料整理，不做任何诊断。")
    _log("   如有异常指标，请及时联系主治医生。")

    # ── 步骤10：发布到 EdgeOne Pages（可选）──
    if publish and result.report_paths:
        if not confirm_public:
            raise RuntimeError("公网发布必须显式设置 confirm_public=True")
        _log("\n【步骤9】发布到公网...")
        publish_dir = out_dir
        if desensitize_public:
            from scripts.desensitize import desensitize_for_output
            public_dir = ensure_private_dir(p_dir / "output_public")
            public_manifest = desensitize_for_output(m)
            render_report.render_md(public_manifest, timeline=timeline_entries, output_path=public_dir / "case_report.md", report_context=report_ctx)
            render_report.render_html(public_manifest, timeline=timeline_entries, output_path=public_dir / "case_report.html", report_context=report_ctx)
            publish_dir = public_dir
        pub = _publish_report(patient_id, report_dir=publish_dir, dry_run=publish_dry_run)
        result.publish_status = pub.get("status")
        result.publish_url = pub.get("location")
        if pub.get("location"):
            _log(f"   🔗 公网链接: {pub['location']}")
        else:
            _log(f"   ⚠️ 发布失败: {pub.get('response', '')[:200]}")

    # ── 步骤11：记录记忆（每次运行都留痕）──
    _log("\n【步骤10】记录处理记忆...")
    mem_info = record_run(
        patient_id,
        pipeline_result={
            "patient_id": result.patient_id,
            "files_total": result.files_total,
            "files_processed": result.files_processed,
            "files_pending_ocr": result.files_pending_ocr,
            "files_failed": result.files_failed,
            "timeline_events": result.timeline_events,
            "critical_alerts_count": result.critical_alerts,
            "critical_alerts": report_ctx.get("critical_alerts", []),
            "output_dir": str(result.output_dir),
            "manifest_path": str(result.manifest_path) if result.manifest_path else None,
            "publish_url": result.publish_url,
            "publish_status": result.publish_status,
            "report_paths": [str(p) for p in result.report_paths],
        },
        input_dir=str(input_dir),
        files_processed=file_records,
    )
    _log(f"   📝 记忆已记录: 版本 {mem_info.get('version_id', '-')}")
    if mem_info.get("publish_url"):
        _log(f"   🔗 可回溯链接: {mem_info['publish_url']}")

    return result
